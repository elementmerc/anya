# Path overrides — redirect stub crates to real content.
# In The Anya Protocol monorepo layout, proprietary lives as a sibling
# directory of engine/, so the relative path is "../proprietary/...".
# Copy this file to .cargo/config.toml after the proprietary repo is
# present at ../proprietary:
#   cp .cargo/config.toml.example .cargo/config.toml
paths = ["../proprietary/scoring", "../proprietary/data"]
