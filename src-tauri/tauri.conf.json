{
  "productName": "Anya",
  "version": "1.0.1",
  "identifier": "com.anya.analyzer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
    "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'",
    "dangerousDisableAssetCspModification": false
  },
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Anya",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "backgroundColor": "#0d0d0f"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
