{
  "productName": "Anya",
  "version": "1.0.2",
  "identifier": "com.anya.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'",
      "dangerousDisableAssetCspModification": false
    },
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Anya",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "backgroundColor": "#0d0d0f"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "Daniel Iwugo",
    "copyright": "Copyright © 2026 Daniel Iwugo",
    "homepage": "https://danieliwugo.com",
    "shortDescription": "Local malware analysis platform",
    "longDescription": "Anya performs static malware analysis locally. No files are uploaded, no data is transmitted, and no network connections are made.",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer/header.bmp",
        "sidebarImage": "icons/installer/sidebar.bmp",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "startMenuFolder": "Anya"
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "dmg": {
        "background": "icons/installer/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      },
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "providerShortName": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ],
        "section": "utils",
        "priority": "optional"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "category": "Utility"
  }
}
