{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Anya default capabilities — read-only filesystem + file dialogs. No network.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:event:default"
  ]
}
