{
  "defaultAction": "SCMP_ACT_ERRNO",
  "architectures": [
    "SCMP_ARCH_X86_64",
    "SCMP_ARCH_AARCH64"
  ],
  "syscalls": [
    {
      "comment": "Syscalls required by a Rust binary doing file I/O and stdout",
      "names": [
        "read",
        "write",
        "writev",
        "open",
        "openat",
        "close",
        "fstat",
        "stat",
        "lstat",
        "mmap",
        "mprotect",
        "munmap",
        "mremap",
        "madvise",
        "brk",
        "rt_sigaction",
        "rt_sigprocmask",
        "rt_sigreturn",
        "ioctl",
        "pread64",
        "pwrite64",
        "access",
        "faccessat",
        "execve",
        "arch_prctl",
        "exit_group",
        "exit",
        "futex",
        "getcwd",
        "getdents64",
        "getpid",
        "gettid",
        "getuid",
        "getgid",
        "geteuid",
        "getegid",
        "lseek",
        "newfstatat",
        "prlimit64",
        "readlink",
        "readlinkat",
        "rseq",
        "set_robust_list",
        "set_tid_address",
        "sysinfo",
        "uname",
        "getrandom",
        "sigaltstack",
        "clock_gettime",
        "clock_getres",
        "clock_nanosleep",
        "nanosleep",
        "sched_yield",
        "sched_getaffinity",
        "clone",
        "clone3",
        "wait4",
        "munlock",
        "unlink",
        "mkdir",
        "rename",
        "fcntl",
        "dup",
        "dup2",
        "dup3",
        "pipe",
        "pipe2",
        "select",
        "pselect6",
        "poll",
        "ppoll",
        "epoll_create1",
        "epoll_ctl",
        "epoll_wait",
        "epoll_pwait",
        "sendfile",
        "socket",
        "connect",
        "getsockname",
        "getpeername",
        "setsockopt",
        "getsockopt",
        "recvfrom",
        "sendto",
        "shutdown",
        "bind",
        "listen",
        "accept",
        "accept4"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Explicitly block dangerous syscalls that should never run in a static analyser",
      "names": [
        "ptrace",
        "kexec_load",
        "kexec_file_load",
        "mount",
        "pivot_root",
        "reboot"
      ],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    }
  ]
}
