# Rust
/target/
**/*.rs.bk
*.pdb

# Coverage reports
tarpaulin-report.html
*.profraw
*.profdata
lcov.info
coverage/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
desktop.ini
.AppleDouble
.LSOverride

# Test outputs
/tests/fixtures/*.exe
/tests/fixtures/*.dll
/tests/fixtures/*.sys
!/tests/fixtures/simple.exe

# Build artifacts
*.so
*.dylib
*.dll
*.a
*.lib

# Personal additions
*.rs.bk
tests/test files/Notepad.exe
node_modules
*Zone.Identifier*

# Integration test script and assets (not for public repo)
scripts/
.github/DOCKER_SETUP.md

# Frontend build output — regenerated by `npm run build`
dist/

# Tauri-specific build directories
src-tauri/target/
.tauri/

# Distribution packages — never commit binary installers
*.deb
*.AppImage
*.dmg
*.msi

# Environment and secrets — never commit keys or local env overrides
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx

# Local analysis databases — contain user data, must not be committed
*.sqlite
*.sqlite3
*.db
anya.db

# Log files
*.log

# Debian packaging working directories — generated by dpkg-buildpackage
debian/anya/
debian/.debhelper/
debian/files
debian/anya.substvars

# Test assets with real malware samples — must never be committed
# (covered by scripts/ above, but listed explicitly as a safety net)
scripts/test_assets/
prompts.txt

anya_env/
